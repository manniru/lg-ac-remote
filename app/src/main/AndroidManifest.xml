<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission to use the IR Blaster -->
    <uses-permission android:name="android.permission.TRANSMIT_IR" />

    <!-- Tell Google Play that the IR hardware is required (optional, but good practice) -->
    <uses-feature android:name="android.hardware.consumerir" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LgAcRemote">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.LgAcRemote">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>